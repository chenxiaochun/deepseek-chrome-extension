{
  "name": "deepseek-chrome-extension",
  "description": "DeepSeek Chrome extension with web chat sync",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
